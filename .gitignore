# Build output
build/
build*/
out/
cmake-build-*/

# CMake-generated files (in case anything configures in-source)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
compile_commands.json
_deps/

# FetchContent-fetched dependency sources (re-fetched on demand, not vendored)
external/*
!external/.gitkeep

# Docs
docs/

# Visual Studio
.vs/
*.sln
*.vcxproj*
*.suo
*.user
*.ilk
*.pdb

# VS Code (keep shared config, ignore personal machine state)
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/c_cpp_properties.json

# Compiled objects / binaries
*.obj
*.o
*.a
*.lib
*.exp
*.exe
*.dll
*.so
*.dylib

# OS cruft
Thumbs.db
desktop.ini
.DS_Store
